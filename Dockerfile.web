## syntax=docker/dockerfile:1.6
# ───────────────────────────────────────────────────────────────────────
# Stage 1 — build
# ───────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS build
RUN corepack enable && corepack prepare pnpm@8.15.4 --activate
WORKDIR /app

# Copy ALL workspace package.json files so pnpm resolves the full
# lockfile correctly (vite and other devDeps are hoisted to root).
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY packages/shared/package.json packages/shared/
RUN pnpm install --frozen-lockfile --shamefully-hoist

COPY tsconfig.base.json ./
COPY apps/web apps/web
COPY packages/shared packages/shared

# Ensure a single React instance
RUN find /app/node_modules -path "*/node_modules/react/package.json" \
    ! -path "/app/node_modules/.pnpm/react@*/node_modules/react/package.json" \
    -exec dirname {} \; 2>/dev/null | xargs -r rm -rf 2>/dev/null || true

ARG CACHEBUST=1
# VITE_API_URL is baked into the bundle at build time. Leave empty for the
# nginx-proxied / docker-compose case (calls go to /api on the same origin).
# On Railway with split services, set this to the API service's public URL.
ARG VITE_API_URL=""
ENV VITE_API_URL=$VITE_API_URL
RUN echo "Build: $CACHEBUST  API: ${VITE_API_URL:-<same-origin>}" && cd apps/web && /app/node_modules/.bin/vite build

# ───────────────────────────────────────────────────────────────────────
# Stage 2 — runtime (nginx, non-root)
# ───────────────────────────────────────────────────────────────────────
FROM nginx:alpine AS runtime

COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
