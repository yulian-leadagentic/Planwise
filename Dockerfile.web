## syntax=docker/dockerfile:1.6
# ───────────────────────────────────────────────────────────────────────
# Stage 1 — build
# ───────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS build
RUN corepack enable && corepack prepare pnpm@8.15.4 --activate
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
RUN pnpm install --frozen-lockfile

COPY apps/web apps/web
COPY packages/shared packages/shared

# Ensure a single React instance
RUN find /app/node_modules -path "*/node_modules/react/package.json" \
    ! -path "/app/node_modules/.pnpm/react@*/node_modules/react/package.json" \
    -exec dirname {} \; 2>/dev/null | xargs -r rm -rf 2>/dev/null || true

ARG CACHEBUST=1
RUN echo "Build: $CACHEBUST" && cd apps/web && pnpm exec vite build

# ───────────────────────────────────────────────────────────────────────
# Stage 2 — runtime (nginx, non-root)
# ───────────────────────────────────────────────────────────────────────
FROM nginx:alpine AS runtime

COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf

# nginx:alpine already runs worker processes as the nginx user; the master
# must run as root to bind :80. For a true non-root container we'd switch
# to unprivileged nginx (port 8080). Keep default for now to avoid
# breaking the existing :80 port binding — flagged for future hardening.

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
