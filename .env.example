# ─── REQUIRED — app will fail to boot without these ─────────────────

# Database — used by API at runtime + Prisma migrations
DATABASE_URL=mysql://amec:your_password@localhost:3306/amec

# JWT secrets — MUST be at least 32 random characters each.
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-CHANGE-ME
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-CHANGE-ME

# ─── docker-compose only (DB container init) ────────────────────────
MYSQL_ROOT_PASSWORD=root_password_CHANGE_ME
MYSQL_DATABASE=amec
MYSQL_USER=amec
MYSQL_PASSWORD=your_password_CHANGE_ME

# Legacy (kept for any scripts that read these)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amec
DB_USER=amec
DB_PASSWORD=your_password
DB_ROOT_PASSWORD=root_password

# ─── OPTIONAL ───────────────────────────────────────────────────────

JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@amec.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
