<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task Assignment</title>
  <style>
    body { font-family: Arial, sans-serif; background-color: #f5f5f5; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
    .header { background-color: #1a56db; padding: 30px; text-align: center; }
    .header h1 { color: #ffffff; margin: 0; font-size: 24px; }
    .body { padding: 30px; }
    .task-info { background: #f0f4ff; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .task-info p { margin: 5px 0; }
    .priority-high { color: #dc2626; font-weight: bold; }
    .priority-medium { color: #d97706; font-weight: bold; }
    .priority-low { color: #16a34a; font-weight: bold; }
    .btn { display: inline-block; background-color: #1a56db; color: #ffffff; text-decoration: none; padding: 12px 30px; border-radius: 6px; font-weight: bold; margin: 15px 0; }
    .footer { padding: 20px 30px; text-align: center; color: #666; font-size: 12px; border-top: 1px solid #eee; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>AMEC</h1>
    </div>
    <div class="body">
      <h2>Task Assigned to You</h2>
      <p>Hello {{assigneeName}},</p>
      <p>A task has been assigned to you by <strong>{{assignerName}}</strong>:</p>
      <div class="task-info">
        <p><strong>Task:</strong> {{taskName}}</p>
        <p><strong>Project:</strong> {{projectName}}</p>
        <p><strong>Label:</strong> {{labelPath}}</p>
        <p><strong>Priority:</strong> <span class="priority-{{priority}}">{{priority}}</span></p>
        {{#if dueDate}}
        <p><strong>Due Date:</strong> {{dueDate}}</p>
        {{/if}}
        {{#if description}}
        <p><strong>Description:</strong> {{description}}</p>
        {{/if}}
      </div>
      <a href="{{taskUrl}}" class="btn">View Task</a>
    </div>
    <div class="footer">
      <p>&copy; {{year}} AMEC Project Management. All rights reserved.</p>
    </div>
  </div>
</body>
</html>
