// ─── Business Partners ──────────────────────────────────────────────────────
//
// SAP-BP-inspired model: every person AND every organization (employee,
// customer, supplier, consultant, external contact, municipality, partner
// company, etc.) is a BusinessPartner. A BP can have multiple roles
// (employee + consultant), and multiple relationships to projects /
// organizations / etc. with their own context-specific role label.
//
// User remains the auth-bearing identity; a User row points to its BP via
// User.businessPartnerId. BPs without a User row are non-login partners.

model BusinessPartner {
  id           Int            @id @default(autoincrement())
  partnerType  PartnerType    @map("partner_type")
  displayName  String         @map("display_name") @db.VarChar(255)
  // Person-only (nullable for orgs)
  firstName    String?        @map("first_name") @db.VarChar(100)
  lastName     String?        @map("last_name")  @db.VarChar(100)
  // Org-typically (nullable for persons; persons can also have an
  // employer relationship — see BusinessPartnerRelationship)
  companyName  String?        @map("company_name") @db.VarChar(255)
  taxId        String?        @map("tax_id")       @db.VarChar(50)
  // Common contact info
  email        String?        @unique @db.VarChar(255)
  phone        String?        @db.VarChar(50)
  mobile       String?        @db.VarChar(50)
  address      String?        @db.VarChar(500)
  website      String?        @db.VarChar(255)
  // Meta
  status       String         @default("active") @db.VarChar(20)
  source       PartnerSource  @default(manual)
  notes        String?        @db.Text

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt      @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  user                  User?                          @relation("UserBusinessPartner")
  roles                 BusinessPartnerRole[]
  outgoingRelationships BusinessPartnerRelationship[]  @relation("RelationshipSource")

  @@index([partnerType])
  @@index([status])
  @@index([companyName])
  @@index([deletedAt])
  @@map("business_partners")
}

// Lookup table for what KIND of business roles a partner can hold.
// Predefined seeds: employee, customer, supplier, consultant,
// external_contact, subcontractor. Admins can add their own; system
// rows are protected from deletion (UI enforces; isSystem flag).
model PartnerRoleType {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  sortOrder   Int       @default(0) @map("sort_order")
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  roles BusinessPartnerRole[]

  @@map("partner_role_types")
}

// Lookup table for what KIND of relationships a partner can have to a
// target. Predefined seeds (system, isSystem=true):
//   worker_of               — person → organization
//   customer_of_project     — organization (customer) → project
//   supplier_of_project     — organization (supplier) → project
//   participates_in_project — person → project (role_in_context = "Project Manager", etc.)
// Validation rules (applicableSourceType / applicableTargetTypes /
// requiredSourceRoleCode) are evaluated by the relationship service, so
// admins can define new types without code changes.
model PartnerRelationshipType {
  id                    Int       @id @default(autoincrement())
  code                  String    @unique @db.VarChar(50)
  name                  String    @db.VarChar(100)
  description           String?   @db.VarChar(500)
  // CSV of RelationshipTarget values this type applies to:
  // e.g. "project,organization". Empty/NULL = any target.
  applicableTargetTypes String?   @map("applicable_target_types") @db.VarChar(255)
  // CSV of PartnerType values this type's source must be:
  // "person", "organization", or "person,organization". NULL/empty = any.
  applicableSourceType  String?   @map("applicable_source_type")  @db.VarChar(50)
  // If set, the source BP must hold this PartnerRoleType.code on its roles.
  // E.g. customer_of_project → "customer" so only customer orgs qualify.
  requiredSourceRoleCode String?  @map("required_source_role_code") @db.VarChar(50)
  sortOrder             Int       @default(0) @map("sort_order")
  isSystem              Boolean   @default(false) @map("is_system")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")

  relationships BusinessPartnerRelationship[]

  @@map("partner_relationship_types")
}

model BusinessPartnerRole {
  id                Int       @id @default(autoincrement())
  businessPartnerId Int       @map("business_partner_id")
  roleTypeId        Int       @map("role_type_id")
  isPrimary         Boolean   @default(false) @map("is_primary")
  validFrom         DateTime? @map("valid_from")
  validTo           DateTime? @map("valid_to")
  createdAt         DateTime  @default(now()) @map("created_at")

  partner   BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)
  roleType  PartnerRoleType @relation(fields: [roleTypeId], references: [id])

  @@unique([businessPartnerId, roleTypeId])
  @@index([businessPartnerId])
  @@index([roleTypeId])
  @@map("business_partner_roles")
}

model BusinessPartnerRelationship {
  id                 Int                       @id @default(autoincrement())
  sourcePartnerId    Int                       @map("source_partner_id")
  targetType         RelationshipTarget        @map("target_type")
  targetId           Int                       @map("target_id")              // polymorphic — not a hard FK
  relationshipTypeId Int                       @map("relationship_type_id")
  roleInContext      String?                   @map("role_in_context") @db.VarChar(255)
  isPrimary          Boolean                   @default(false) @map("is_primary")
  // BUT050-style time-bounded validity. valid_from defaults to now(),
  // valid_to defaults to far-future (open-ended). On "disconnect", the
  // service sets valid_to = now() instead of deleting — preserves history.
  validFrom          DateTime                  @default(now())              @map("valid_from")
  validTo            DateTime                  @default(dbgenerated("'9999-12-31 00:00:00'"))  @map("valid_to")
  status             String                    @default("active") @db.VarChar(20)
  notes              String?                   @db.Text
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt      @map("updated_at")

  source           BusinessPartner          @relation("RelationshipSource", fields: [sourcePartnerId], references: [id], onDelete: Cascade)
  relationshipType PartnerRelationshipType  @relation(fields: [relationshipTypeId], references: [id])

  @@unique([sourcePartnerId, targetType, targetId, relationshipTypeId])
  @@index([sourcePartnerId])
  @@index([targetType, targetId])
  @@index([relationshipTypeId])
  @@map("business_partner_relationships")
}
