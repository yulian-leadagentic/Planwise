generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserType {
  employee
  partner
  both
}

enum ProjectStatus {
  draft
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  not_started
  in_progress
  in_review
  completed
  on_hold
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  critical
}

enum CalendarDayType {
  holiday
  company_day_off
  half_day
  special
}

enum CalendarDayAppliesTo {
  all
  employees_only
  partners_only
}

enum TimeClockStatus {
  clocked_in
  completed
  auto_closed
  edited
  absent
  leave
  sick
}

enum ClockType {
  regular
  overtime
  remote
  field
}

enum ContractStatus {
  draft
  active
  completed
  cancelled
}

enum BillingType {
  generated
  requested
}

enum BillingStatus {
  draft
  sent
  approved
  paid
  rejected
}

enum ExpenseType {
  material
  labor
  travel
  equipment
  subcontractor
  other
}

enum ActivityCategory {
  auth
  project
  task
  time
  contract
  user
  system
  admin
}

enum ActivitySeverity {
  info
  warn
  error
  critical
}

enum EmailLogStatus {
  sent
  failed
}

enum ProjectRole {
  project_leader        @map("project_leader")
  bim_manager           @map("bim_manager")
  bim_lead              @map("bim_lead")
  mep_coordinator       @map("mep_coordinator")
  mep_lead              @map("mep_lead")
  coordinator
  professional_employee @map("professional_employee")
  viewer
}

enum ZoneType {
  site
  building
  level
  zone
  area
  section
  wing
  floor
}

enum TemplateType {
  task_list   @map("task_list")
  zone
  combined
}

enum MessageEntityType {
  project
  task
  zone
}

enum MessageType {
  user
  system
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  password     String
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  phone        String?
  avatarUrl    String?   @map("avatar_url")
  roleId       Int       @map("role_id")
  userType     UserType  @map("user_type")
  position     String?
  department   String?
  companyName  String?   @map("company_name")
  taxId        String?   @map("tax_id")
  address      String?
  website      String?
  otpCode      String?   @map("otp_code")
  otpExpiresAt DateTime? @map("otp_expires_at")
  otpAttempts  Int       @default(0) @map("otp_attempts")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id])

  projectsCreated      Project[]          @relation("ProjectCreatedBy")
  projectsLed          Project[]          @relation("ProjectLeader")
  projectMembers       ProjectMember[]
  taskAssignees        TaskAssignee[]
  taskComments         TaskComment[]
  workSchedules        WorkSchedule[]
  calendarDaysCreated  CalendarDay[]      @relation("CalendarDayCreatedBy")
  timeClocks           TimeClock[]        @relation("TimeClockUser")
  timeClocksApproved   TimeClock[]        @relation("TimeClockApprovedBy")
  timeClocksEdited     TimeClock[]        @relation("TimeClockEditedBy")
  timeEntries          TimeEntry[]
  contractsAsPartner   Contract[]         @relation("ContractPartner")
  contractsCreated     Contract[]         @relation("ContractCreatedBy")
  milestonesAsPartner  LabelMilestone[]   @relation("MilestonePartner")
  milestonesCreated    LabelMilestone[]   @relation("MilestoneCreatedBy")
  contacts             Contact[]
  expensesCreated      Expense[]
  terms                Term[]
  activityLogs         ActivityLog[]
  notifications        Notification[]
  billingsCreated      Billing[]
  teamTemplates        TeamTemplate[]
  teamTemplateMembers  TeamTemplateMember[]
  tasksCreated         Task[]             @relation("TaskCreator")
  templatesCreated     Template[]         @relation("TemplateCreator")
  messages             Message[]          @relation("MessageAuthor")
  messageMentions      MessageMention[]
  taskAttachments      TaskAttachment[]
  notificationsActed   Notification[]     @relation("NotificationActor")
  notificationPrefs    NotificationPreference[]

  @@index([roleId])
  @@index([email])
  @@index([userType])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  roleModules RoleModule[]

  @@map("roles")
}

model Module {
  id        Int      @id @default(autoincrement())
  name      String
  route     String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  parentId  Int?     @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Module?  @relation("ModuleParent", fields: [parentId], references: [id])
  children Module[] @relation("ModuleParent")

  roleModules RoleModule[]

  @@index([parentId])
  @@map("modules")
}

model RoleModule {
  id        Int     @id @default(autoincrement())
  roleId    Int     @map("role_id")
  moduleId  Int     @map("module_id")
  canRead   Boolean @default(false) @map("can_read")
  canWrite  Boolean @default(false) @map("can_write")
  canDelete Boolean @default(false) @map("can_delete")

  role   Role   @relation(fields: [roleId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@index([roleId])
  @@index([moduleId])
  @@map("role_modules")
}

model ProjectType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @db.VarChar(20)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("project_types")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("departments")
}

model Project {
  id            Int           @id @default(autoincrement())
  name          String
  number        String?
  description   String?
  projectTypeId Int           @map("project_type_id")
  departmentId  Int?          @map("department_id")
  leaderId      Int?          @map("leader_id")
  status        ProjectStatus @default(draft)
  budget        Decimal?      @db.Decimal(14, 2)
  estimatedValue Decimal?     @map("estimated_value") @db.Decimal(14, 2)
  startDate     DateTime?     @map("start_date")
  endDate       DateTime?     @map("end_date")
  isArchived    Boolean       @default(false) @map("is_archived")
  createdBy     Int           @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  projectType ProjectType  @relation(fields: [projectTypeId], references: [id])
  department  Department?  @relation(fields: [departmentId], references: [id])
  creator     User         @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  leader      User?        @relation("ProjectLeader", fields: [leaderId], references: [id])

  members     ProjectMember[]
  labels      Label[]
  contracts   Contract[]
  expenses    Expense[]
  timeEntries TimeEntry[]
  zones       Zone[]
  tasks       Task[]

  @@index([projectTypeId])
  @@index([departmentId])
  @@index([createdBy])
  @@index([leaderId])
  @@index([status])
  @@index([deletedAt])
  @@map("projects")
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  userId    Int      @map("user_id")
  role      String?
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model Label {
  id          Int       @id @default(autoincrement())
  projectId   Int       @map("project_id")
  parentId    Int?      @map("parent_id")
  labelTypeId Int?      @map("label_type_id")
  name        String
  path        String
  depth       Int       @default(0)
  sortOrder   Int       @default(0) @map("sort_order")
  description String?
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project   Project @relation(fields: [projectId], references: [id])
  parent    Label?  @relation("LabelParent", fields: [parentId], references: [id])
  children  Label[] @relation("LabelParent")

  contractItems ContractItem[]
  milestones    LabelMilestone[]

  @@index([projectId])
  @@index([parentId])
  @@index([labelTypeId])
  @@index([deletedAt])
  @@map("labels")
}

model WorkSchedule {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  name           String
  dayOfWeek      Int       @map("day_of_week")
  shiftStart     String    @map("shift_start")
  shiftEnd       String    @map("shift_end")
  breakMinutes   Int       @default(60) @map("break_minutes")
  isActive       Boolean   @default(true) @map("is_active")
  effectiveFrom  DateTime  @map("effective_from")
  effectiveUntil DateTime? @map("effective_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, dayOfWeek, effectiveFrom])
  @@index([userId])
  @@map("work_schedules")
}

model CalendarDay {
  id          Int                 @id @default(autoincrement())
  date        DateTime            @unique
  name        String
  type        CalendarDayType
  halfDayUntil String?            @map("half_day_until")
  appliesTo   CalendarDayAppliesTo @default(all) @map("applies_to")
  isRecurring Boolean             @default(false) @map("is_recurring")
  notes       String?
  createdBy   Int                 @map("created_by")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  creator User @relation("CalendarDayCreatedBy", fields: [createdBy], references: [id])

  @@index([createdBy])
  @@map("calendar_days")
}

model TimeClock {
  id              Int             @id @default(autoincrement())
  userId          Int             @map("user_id")
  date            DateTime
  clockIn         DateTime        @map("clock_in")
  clockOut        DateTime?       @map("clock_out")
  breakMinutes    Int             @default(0) @map("break_minutes")
  status          TimeClockStatus
  clockType       ClockType       @default(regular) @map("clock_type")
  note            String?
  documentUrl     String?         @map("document_url")
  approvedBy      Int?            @map("approved_by")
  approvedAt      DateTime?       @map("approved_at")
  editedBy        Int?            @map("edited_by")
  editedReason    String?         @map("edited_reason")
  totalMinutes    Int?            @map("total_minutes")
  expectedMinutes Int?            @map("expected_minutes")
  overtimeMinutes Int?            @map("overtime_minutes")
  isLate          Boolean         @default(false) @map("is_late")
  lateMinutes     Int             @default(0) @map("late_minutes")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  user     User  @relation("TimeClockUser", fields: [userId], references: [id])
  approver User? @relation("TimeClockApprovedBy", fields: [approvedBy], references: [id])
  editor   User? @relation("TimeClockEditedBy", fields: [editedBy], references: [id])

  timeEntries TimeEntry[]

  @@index([userId])
  @@index([userId, date])
  @@index([approvedBy])
  @@index([editedBy])
  @@index([date])
  @@index([status])
  @@map("time_clock")
}

model TimeEntry {
  id          Int            @id @default(autoincrement())
  userId      Int            @map("user_id")
  timeClockId Int?           @map("time_clock_id")
  projectId   Int?           @map("project_id")
  taskId      Int?           @map("task_id")
  date        DateTime
  startTime   String?        @map("start_time") @db.VarChar(5)
  endTime     String?        @map("end_time") @db.VarChar(5)
  minutes     Int
  note        String?
  isBillable  Boolean        @default(true) @map("is_billable")
  location    String?        @db.VarChar(20)
  completionPct Int?         @map("completion_pct")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  user       User        @relation(fields: [userId], references: [id])
  timeClock  TimeClock?  @relation(fields: [timeClockId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  task       Task?       @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([timeClockId])
  @@index([projectId])
  @@index([taskId])
  @@index([date])
  @@index([deletedAt])
  @@map("time_entries")
}

model Contract {
  id          Int            @id @default(autoincrement())
  name        String
  projectId   Int?           @map("project_id")
  partnerId   Int            @map("partner_id")
  status      ContractStatus @default(draft)
  totalAmount Decimal?       @map("total_amount") @db.Decimal(14, 2)
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  notes       String?
  createdBy   Int            @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")

  project Project? @relation(fields: [projectId], references: [id])
  partner User     @relation("ContractPartner", fields: [partnerId], references: [id])
  creator User     @relation("ContractCreatedBy", fields: [createdBy], references: [id])

  items    ContractItem[]
  billings Billing[]

  currency String? @default("ILS") @db.VarChar(3)
  pdfUrl   String? @map("pdf_url") @db.VarChar(500)

  @@index([projectId])
  @@index([partnerId])
  @@index([createdBy])
  @@index([status])
  @@index([deletedAt])
  @@map("contracts")
}

model ContractItem {
  id          Int       @id @default(autoincrement())
  contractId  Int       @map("contract_id")
  labelId     Int?      @map("label_id")
  milestoneId Int?      @map("milestone_id")
  description String
  quantity    Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  total       Decimal   @db.Decimal(14, 2)
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  contract  Contract        @relation(fields: [contractId], references: [id])
  label     Label?          @relation(fields: [labelId], references: [id])
  milestone LabelMilestone? @relation(fields: [milestoneId], references: [id])

  name String? @db.VarChar(255)

  @@index([contractId])
  @@index([labelId])
  @@index([milestoneId])
  @@map("contract_items")
}

model Billing {
  id          Int           @id @default(autoincrement())
  contractId  Int           @map("contract_id")
  type        BillingType
  amount      Decimal       @db.Decimal(14, 2)
  billingDate DateTime      @map("billing_date")
  description String?
  status      BillingStatus
  pdfUrl      String?       @map("pdf_url")
  createdBy   Int           @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id])
  creator  User     @relation(fields: [createdBy], references: [id])

  @@index([contractId])
  @@index([createdBy])
  @@index([status])
  @@map("billings")
}

model LabelMilestone {
  id          Int       @id @default(autoincrement())
  labelId     Int       @map("label_id")
  partnerId   Int       @map("partner_id")
  name        String
  dueDate     DateTime? @map("due_date")
  amount      Decimal?  @db.Decimal(14, 2)
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  notes       String?
  createdBy   Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  label   Label @relation(fields: [labelId], references: [id])
  partner User  @relation("MilestonePartner", fields: [partnerId], references: [id])
  creator User  @relation("MilestoneCreatedBy", fields: [createdBy], references: [id])

  contractItems ContractItem[]

  @@index([labelId])
  @@index([partnerId])
  @@index([createdBy])
  @@map("label_milestones")
}

model Contact {
  id        Int       @id @default(autoincrement())
  partnerId Int       @map("partner_id")
  name      String
  email     String?
  phone     String?
  role      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  partner User @relation(fields: [partnerId], references: [id])

  @@index([partnerId])
  @@map("contacts")
}

model Expense {
  id          Int         @id @default(autoincrement())
  projectId   Int         @map("project_id")
  expenseType ExpenseType @map("expense_type")
  amount      Decimal     @db.Decimal(14, 2)
  date        DateTime
  description String?
  receiptUrl  String?     @map("receipt_url")
  createdBy   Int         @map("created_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId])
  @@index([createdBy])
  @@index([date])
  @@map("expenses")
}

model Term {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  title         String
  monthlySalary Decimal?  @map("monthly_salary") @db.Decimal(12, 2)
  hourlyRate    Decimal?  @map("hourly_rate") @db.Decimal(10, 2)
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("terms")
}

model ActivityLog {
  id          BigInt           @id @default(autoincrement())
  userId      Int?             @map("user_id")
  sessionId   String?          @map("session_id")
  category    ActivityCategory
  action      String
  severity    ActivitySeverity @default(info)
  entityType  String?          @map("entity_type")
  entityId    Int?             @map("entity_id")
  entityName  String?          @map("entity_name")
  description String
  changes     Json?
  metadata    Json?
  ipAddress   String?          @map("ip_address")
  createdAt   DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([category])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([sessionId])
  @@map("activity_logs")
}

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  type       String
  title      String
  body       String?
  data       Json?
  readAt     DateTime? @map("read_at")
  entityType String?   @map("entity_type")
  entityId   Int?      @map("entity_id")
  actorId    Int?      @map("actor_id")
  messageId  Int?      @map("message_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id])
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id])
  message Message? @relation(fields: [messageId], references: [id])

  @@index([userId])
  @@index([readAt])
  @@index([entityType, entityId])
  @@index([actorId])
  @@map("notifications")
}

model EmailLog {
  id           Int            @id @default(autoincrement())
  toEmail      String         @map("to_email")
  subject      String
  template     String
  status       EmailLogStatus
  errorMessage String?        @map("error_message")
  createdAt    DateTime       @default(now()) @map("created_at")

  @@index([toEmail])
  @@index([status])
  @@map("email_logs")
}

model TeamTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User                 @relation(fields: [createdBy], references: [id])
  members TeamTemplateMember[]

  @@index([createdBy])
  @@map("team_templates")
}

model TeamTemplateMember {
  id             Int     @id @default(autoincrement())
  teamTemplateId Int     @map("team_template_id")
  userId         Int     @map("user_id")
  role           String?

  teamTemplate TeamTemplate @relation(fields: [teamTemplateId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([teamTemplateId])
  @@index([userId])
  @@map("team_template_members")
}

// ─── Zone & Spatial Models ─────────────────────────────────────────────────

model Zone {
  id           Int       @id @default(autoincrement())
  projectId    Int       @map("project_id")
  parentId     Int?      @map("parent_id")
  zoneType     ZoneType  @default(zone) @map("zone_type")
  name         String    @db.VarChar(255)
  code         String?   @db.VarChar(50)
  areaSqm      Decimal?  @map("area_sqm") @db.Decimal(10, 2)
  path         String    @db.VarChar(255)
  depth        Int       @default(0)
  sortOrder    Int       @default(0) @map("sort_order")
  description  String?   @db.Text
  isTypical    Boolean   @default(false) @map("is_typical")
  typicalCount Int       @default(1) @map("typical_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  project          Project           @relation(fields: [projectId], references: [id])
  parent           Zone?             @relation("ZoneTree", fields: [parentId], references: [id])
  children         Zone[]            @relation("ZoneTree")
  tasks            Task[]
  zoneServiceTypes ZoneServiceType[]

  @@unique([projectId, name, deletedAt])
  @@index([projectId])
  @@index([parentId])
  @@index([path])
  @@index([deletedAt])
  @@map("zones")
}

// ─── Service Types & Phases ────────────────────────────────────────────────

model ServiceType {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  code      String?  @db.VarChar(20)
  color     String?  @db.VarChar(7)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  zoneServiceTypes  ZoneServiceType[]
  tasks             Task[]
  templateTasks     TemplateTask[]
  templateZoneTasks TemplateZoneTask[]

  @@map("service_types")
}

model ZoneServiceType {
  id            Int      @id @default(autoincrement())
  zoneId        Int      @map("zone_id")
  serviceTypeId Int      @map("service_type_id")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  zone        Zone        @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  @@unique([zoneId, serviceTypeId])
  @@map("zone_service_types")
}

model Phase {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  code      String?  @db.VarChar(20)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks             Task[]
  templates         Template[]
  templateTasks     TemplateTask[]
  templateZoneTasks TemplateZoneTask[]

  @@map("phases")
}

// ─── Tasks ─────────────────────────────────────────────────────────────────

model Task {
  id            Int          @id @default(autoincrement())
  zoneId        Int          @map("zone_id")
  projectId     Int          @map("project_id")
  serviceTypeId Int?         @map("service_type_id")
  code          String       @db.VarChar(50)
  name          String       @db.VarChar(255)
  description   String?      @db.Text
  budgetHours   Decimal?     @map("budget_hours") @db.Decimal(10, 2)
  budgetAmount  Decimal?     @map("budget_amount") @db.Decimal(14, 2)
  phaseId       Int?         @map("phase_id")
  status        TaskStatus   @default(not_started)
  priority      TaskPriority @default(medium)
  completionPct Int          @default(0) @map("completion_pct")
  startDate     DateTime?    @map("start_date") @db.Date
  endDate       DateTime?    @map("end_date") @db.Date
  sortOrder     Int          @default(0) @map("sort_order")
  isArchived    Boolean      @default(false) @map("is_archived")
  createdBy     Int          @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  zone         Zone         @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id])
  serviceType  ServiceType? @relation(fields: [serviceTypeId], references: [id])
  phase        Phase?       @relation(fields: [phaseId], references: [id])
  creator      User         @relation("TaskCreator", fields: [createdBy], references: [id])
  assignees    TaskAssignee[]
  comments     TaskComment[]
  attachments  TaskAttachment[]
  timeEntries  TimeEntry[]
  dependencies TaskDependency[] @relation("TaskDeps")
  dependedBy   TaskDependency[] @relation("TaskDepBy")

  @@index([zoneId])
  @@index([projectId])
  @@index([serviceTypeId])
  @@index([status])
  @@map("tasks")
}

model TaskAttachment {
  id           Int      @id @default(autoincrement())
  taskId       Int      @map("task_id")
  fileName     String   @map("file_name") @db.VarChar(255)
  fileUrl      String   @map("file_url") @db.VarChar(500)
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(100)
  uploadedBy   Int      @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@index([taskId])
  @@map("task_attachments")
}

model TaskDependency {
  id          Int @id @default(autoincrement())
  taskId      Int @map("task_id")
  dependsOnId Int @map("depends_on_id")

  task      Task @relation("TaskDeps", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDepBy", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

model TaskAssignee {
  id         Int       @id @default(autoincrement())
  taskId     Int       @map("task_id")
  userId     Int       @map("user_id")
  role       String?   @db.VarChar(50)
  hourlyRate Decimal?  @map("hourly_rate") @db.Decimal(10, 2)
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  taskId    Int       @map("task_id")
  userId    Int       @map("user_id")
  parentId  Int?      @map("parent_id")
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  task    Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
  parent  TaskComment? @relation("CommentThread", fields: [parentId], references: [id])
  replies TaskComment[] @relation("CommentThread")

  @@index([taskId])
  @@map("task_comments")
}

// ─── Templates ─────────────────────────────────────────────────────────────

model Template {
  id          Int          @id @default(autoincrement())
  code        String       @db.VarChar(50)
  name        String       @db.VarChar(255)
  type        TemplateType
  category    String?      @db.VarChar(100)
  description String?      @db.Text
  phaseId     Int?         @map("phase_id")
  isActive    Boolean      @default(true) @map("is_active")
  usageCount  Int          @default(0) @map("usage_count")
  createdBy   Int          @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  creator            User           @relation("TemplateCreator", fields: [createdBy], references: [id])
  phase              Phase?         @relation(fields: [phaseId], references: [id])
  templateTasks      TemplateTask[]
  templateZones      TemplateZone[]
  linkedZones        TemplateZone[] @relation("LinkedTaskTemplate")
  referencedByZones  TemplateZone[] @relation("ReferencedZoneTemplate")

  @@map("templates")
}

model TemplateTask {
  id                  Int          @id @default(autoincrement())
  templateId          Int          @map("template_id")
  serviceTypeId       Int?         @map("service_type_id")
  code                String       @db.VarChar(50)
  name                String       @db.VarChar(255)
  description         String?      @db.Text
  defaultBudgetHours  Decimal?     @map("default_budget_hours") @db.Decimal(10, 2)
  defaultBudgetAmount Decimal?     @map("default_budget_amount") @db.Decimal(14, 2)
  defaultPriority     TaskPriority @default(medium) @map("default_priority")
  phaseId             Int?         @map("phase_id")
  sortOrder           Int          @default(0) @map("sort_order")
  createdAt           DateTime     @default(now()) @map("created_at")

  template    Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  serviceType ServiceType? @relation(fields: [serviceTypeId], references: [id])
  phase       Phase?       @relation(fields: [phaseId], references: [id])

  @@map("template_tasks")
}

model TemplateZone {
  id                     Int      @id @default(autoincrement())
  templateId             Int      @map("template_id")
  parentId               Int?     @map("parent_id")
  zoneType               ZoneType @default(zone) @map("zone_type")
  name                   String   @db.VarChar(255)
  code                   String?  @db.VarChar(50)
  isTypical              Boolean  @default(false) @map("is_typical")
  typicalCount           Int      @default(1) @map("typical_count")
  sortOrder              Int      @default(0) @map("sort_order")
  linkedTaskTemplateId   Int?     @map("linked_task_template_id")
  referencedTemplateId   Int?     @map("referenced_template_id")
  createdAt              DateTime @default(now()) @map("created_at")

  template             Template          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent               TemplateZone?     @relation("TemplateZoneTree", fields: [parentId], references: [id])
  children             TemplateZone[]    @relation("TemplateZoneTree")
  linkedTaskTemplate   Template?         @relation("LinkedTaskTemplate", fields: [linkedTaskTemplateId], references: [id])
  referencedTemplate   Template?         @relation("ReferencedZoneTemplate", fields: [referencedTemplateId], references: [id])
  templateZoneTasks    TemplateZoneTask[]

  @@map("template_zones")
}

model TemplateZoneTask {
  id                  Int          @id @default(autoincrement())
  templateZoneId      Int          @map("template_zone_id")
  serviceTypeId       Int?         @map("service_type_id")
  code                String       @db.VarChar(50)
  name                String       @db.VarChar(255)
  description         String?      @db.Text
  defaultBudgetHours  Decimal?     @map("default_budget_hours") @db.Decimal(10, 2)
  defaultBudgetAmount Decimal?     @map("default_budget_amount") @db.Decimal(14, 2)
  defaultPriority     TaskPriority @default(medium) @map("default_priority")
  phaseId             Int?         @map("phase_id")
  sortOrder           Int          @default(0) @map("sort_order")
  createdAt           DateTime     @default(now()) @map("created_at")

  templateZone TemplateZone @relation(fields: [templateZoneId], references: [id], onDelete: Cascade)
  serviceType  ServiceType? @relation(fields: [serviceTypeId], references: [id])
  phase        Phase?       @relation(fields: [phaseId], references: [id])

  @@map("template_zone_tasks")
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Message {
  id         Int               @id @default(autoincrement())
  entityType MessageEntityType @map("entity_type")
  entityId   Int               @map("entity_id")
  parentId   Int?              @map("parent_id")
  authorId   Int?              @map("author_id")
  type       MessageType       @default(user)
  content    String            @db.Text
  metadata   Json?
  isEdited   Boolean           @default(false) @map("is_edited")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")

  author         User?            @relation("MessageAuthor", fields: [authorId], references: [id])
  parent         Message?         @relation("MessageThread", fields: [parentId], references: [id])
  replies        Message[]        @relation("MessageThread")
  mentions       MessageMention[]
  notifications  Notification[]

  @@index([entityType, entityId])
  @@index([parentId])
  @@index([authorId])
  @@index([createdAt])
  @@map("messages")
}

model MessageMention {
  id        Int      @id @default(autoincrement())
  messageId Int      @map("message_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_mentions")
}

model NotificationPreference {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  notificationType String   @map("notification_type")
  inApp            Boolean  @default(true) @map("in_app")
  email            Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, notificationType])
  @@index([userId])
  @@map("notification_preferences")
}
